{
  "name": "trader-hub-popout",
  "version": "1.0.0",
  "description": "Always-on-top checklist overlay for Trader Hub",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win nsis",
    "build:portable": "electron-builder --win portable"
  },
  "author": "EMALoTrades",
  "license": "UNLICENSED",
  "private": true,
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "build": {
    "appId": "com.traderhub.popout",
    "productName": "Trader Hub Pop-Out Checklist",
    "forceCodeSigning": false,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Trader Hub Pop-Out"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "icon.ico",
      "icon.png"
    ]
  }
}
